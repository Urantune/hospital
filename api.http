################################
### AUTH
################################

### Register
POST http://localhost:8080/auth/register
Content-Type: application/json

{
  "email": "test@gmail.com",
  "password": "123456"
}

###

### Verify Account
GET http://localhost:8080/auth/verify?token=af606098-a900-48e4-a2cd-7595810c14aa

###

### Login
POST http://localhost:8080/auth/login
Content-Type: application/json

{
  "email": "test@gmail.com",
  "password": "123456"
}

###

### Refresh Access Token
POST http://localhost:8080/auth/refresh
Content-Type: application/json

{
  "refresh_token": "YOUR_REFRESH_TOKEN"
}

################################
### CLINIC
################################

### Create Clinic
POST http://localhost:8080/api/clinics
Authorization: Bearer "YOUR_ACCESS_TOKEN"
Content-Type: application/json

{
  "name": "City Hospital",
  "address": "123 Nguyen Trai",
  "phone": "0909000000",
  "status": "active"
}

################################
### DOCTOR
################################

### Create Doctor
POST http://localhost:8080/api/doctors
Authorization: Bearer "YOUR_ACCESS_TOKEN"
Content-Type: application/json

{
  "user_id": "USER_UUID",
  "clinic_id": "CLINIC_UUID",
  "specialization": "Cardiology"
}

###

### Deactivate Doctor
PUT http://localhost:8080/api/doctors/DOCTOR_UUID/deactivate
Authorization: Bearer "YOUR_ACCESS_TOKEN"

###

### Activate Doctor
PUT http://localhost:8080/api/doctors/DOCTOR_UUID/activate
Authorization: Bearer "YOUR_ACCESS_TOKEN"

################################
### MEDICAL SERVICE
################################

### Create Service
POST http://localhost:8080/api/services
Authorization: Bearer "YOUR_ACCESS_TOKEN"
Content-Type: application/json

{
  "name": "Heart Check",
  "description": "Heart examination",
  "default_duration_minutes": 30
}

###

### Get Services
GET http://localhost:8080/api/services
Authorization: Bearer "YOUR_ACCESS_TOKEN"

################################
### DOCTOR SERVICE MAPPING
################################

### Assign Service To Doctor
POST http://localhost:8080/api/doctor-services
Authorization: Bearer "YOUR_ACCESS_TOKEN"
Content-Type: application/json

{
  "doctor_id": "DOCTOR_UUID",
  "service_id": "SERVICE_UUID",
  "clinic_id": "CLINIC_UUID"
}

################################
### APPOINTMENT
################################

### Create Appointment
POST http://localhost:8080/api/appointments
Authorization: Bearer "YOUR_ACCESS_TOKEN"
Content-Type: application/json

{
  "clinic_id": "CLINIC_UUID",
  "doctor_id": "DOCTOR_UUID",
  "service_id": "SERVICE_UUID",
  "slot_id": "SLOT_UUID",
  "payment_window_expires_at": "2026-03-25T18:00:00Z",
  "total_amount": 500000,
  "user_pay_amount": 300000,
  "insured_amount": 200000
}

### Get My Appointments
GET http://localhost:8080/api/appointments/me
Authorization: Bearer "YOUR_ACCESS_TOKEN"

### Get Appointment Detail
GET http://localhost:8080/api/appointments/APPOINTMENT_UUID
Authorization: Bearer "YOUR_ACCESS_TOKEN"

### Update Appointment Status
PATCH http://localhost:8080/api/appointments/APPOINTMENT_UUID/status
Authorization: Bearer "YOUR_ACCESS_TOKEN"
Content-Type: application/json

{
  "status": "CONFIRMED",
  "reason": "Payment verified"
}

### Get Appointment History
GET http://localhost:8080/api/appointments/APPOINTMENT_UUID/history
Authorization: Bearer "YOUR_ACCESS_TOKEN"

################################
### CMS SYNC
################################

### Sync Clinic From CMS
POST http://localhost:8080/api/cms/sync
Authorization: Bearer "YOUR_ACCESS_TOKEN"
X-CMS-Signature: YOUR_SIGNATURE
Content-Type: application/json

{
  "event_id": "evt-clinic-001",
  "source": "directus",
  "entity_type": "clinic",
  "entity_id": "CLINIC_UUID",
  "action": "updated",
  "payload": {
    "id": "CLINIC_UUID",
    "name": "City Hospital Updated",
    "address": "123 Nguyen Trai",
    "phone": "0909000000",
    "status": "active"
  }
}

### Sync Medical Service From CMS
POST http://localhost:8080/api/cms/sync
Authorization: Bearer "YOUR_ACCESS_TOKEN"
X-CMS-Signature: YOUR_SIGNATURE
Content-Type: application/json

{
  "event_id": "evt-service-001",
  "source": "directus",
  "entity_type": "medical_service",
  "entity_id": "SERVICE_UUID",
  "action": "created",
  "payload": {
    "id": "SERVICE_UUID",
    "name": "Heart Check Plus",
    "description": "Heart examination",
    "default_duration_minutes": 45,
    "status": "active"
  }
}



################################
### USER
################################

### Logout
POST http://localhost:8080/api/logout
Authorization: Bearer "YOUR_ACCESS_TOKEN"


### Appointment precondition validation
POST http://localhost:8080/api/appointments
Authorization: Bearer ACCESS_TOKEN
Content-Type: application/json

{
  "clinic_id": "CLINIC_ID",
  "doctor_id": "DOCTOR_ID",
  "service_id": "SERVICE_ID",
  "slot_id": "SLOT_ID"
}

###
GET http://localhost:8080/api/activities
Authorization: Bearer ACCESS_TOKEN

### Appointment state machine
PATCH http://localhost:8080/api/appointments/{id}/status
Authorization: Bearer ACCESS_TOKEN

{
"status": "CONFIRMED"
}




###
Register
   ↓
Login
   ↓
Create Clinic
   ↓
Create Doctor
   ↓
Create Service
   ↓
Assign Service to Doctor
